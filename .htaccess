# Money Management — Root Security Rules
Options -Indexes
ServerSignature Off

# Landing page as default
DirectoryIndex index.php

# ── Block sensitive file types ──────────────────────────────────────────────
<FilesMatch "\.(log|bak|tmp|sql|env|sh|conf|config|ini|swp|swo|git)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── Block sensitive directories (direct browser navigation) ─────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block direct access to purely internal directories (not API)
    RewriteRule ^(includes|auth|admin|dashboard|Exp|Sav|\.git|database)(/|$) - [F,L]
</IfModule>

# ── Protect api/ — allow AJAX calls, block direct browser navigation ─────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block GET requests to api/ directory (directory listing / direct browse)
    # Allow POST (AJAX fetch calls from the app)
    RewriteCond %{REQUEST_METHOD} GET
    RewriteCond %{HTTP_ACCEPT} !application/json
    RewriteCond %{HTTP:X-Requested-With} !XMLHttpRequest
    RewriteRule ^api/$ - [F,L]
</IfModule>

# ── Block direct browser access to dev.php (allow only if needed locally) ───
<Files "dev.php">
    Order Allow,Deny
    Deny from all
</Files>

# ── Block session_ping.php from direct browser requests ─────────────────────
<Files "session_ping.php">
    <IfModule mod_rewrite.c>
        RewriteEngine On
        RewriteCond %{HTTP_ACCEPT} !application/json
        RewriteCond %{HTTP:X-Requested-With} !XMLHttpRequest
        RewriteRule ^ - [F,L]
    </IfModule>
</Files>

# ── Force HTTPS — works with InfinityFree/Cloudflare proxy ──────────────────
# Checks both the standard HTTPS flag and the Cloudflare forwarded-proto header
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Standard HTTPS check
    RewriteCond %{HTTPS} off
    # AND not coming through Cloudflare/proxy as HTTPS
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── Centralized Error Page Handlers ─────────────────────────────────────────
# (If your project is in a subdirectory on the server, e.g. /PROJECT M/, prepend it: /PROJECT M/error.php?code=...)
ErrorDocument 404 /error.php?code=url_tamper
ErrorDocument 403 /error.php?code=unauthorized
ErrorDocument 500 /error.php?code=db
