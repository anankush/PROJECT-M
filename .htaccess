# PROJECT M — Root Security Rules
Options -Indexes
ServerSignature Off

# Landing page as default
DirectoryIndex index.php

# Block access to sensitive directories
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(includes|database|\.git)/ - [F,L]
</IfModule>

# Force HTTPS if available (uncomment on production)
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTPS} off
#     RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>
